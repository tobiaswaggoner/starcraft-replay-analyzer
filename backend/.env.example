# Path to your SC2 replay folder. On Windows typically:
#   C:\Users\<USER>\Documents\StarCraft II\Accounts\<ID>\<REGION>\Replays\Multiplayer
REPLAY_DIR=

# Where the SQLite file lives
DB_PATH=./data/replays.db

# Comma-separated list of your in-game names. Used to mark which player in each
# replay is "you" so the UI can default views to your perspective.
MY_PLAYER_NAMES=

# Backend bind
HOST=127.0.0.1
PORT=8765
